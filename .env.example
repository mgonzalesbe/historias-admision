# Seguridad de la app
SECRET_KEY=CAMBIA_ESTA_SECRET_KEY_EN_PRODUCCION
FLASK_DEBUG=false

# Base de datos SQL Server / Azure SQL
# Para Azure SQL:
# DB_SERVER=tu-servidor.database.windows.net,1433
# DB_TRUSTED=false
DB_SERVER=localhost
DB_NAME=tu_base_de_datos
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUSTED=true
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=no
DB_CONNECTION_TIMEOUT=30

# RPC Solana (Alchemy u otro). Ejemplo Devnet:
ALCHEMY_SOLANA_RPC_URL=https://solana-devnet.g.alchemy.com/v2/TU_API_KEY

# Clave del firmante del backend (NO es la API key de Alchemy).
# Formato aceptado: base58 | hex 128 chars (64 bytes) | JSON [64 ints]
# Generar hex: python scripts/generar_clave_solana.py
SOLANA_SIGNER_PRIVATE_KEY=tu_clave_privada_aqui

# Correo saliente con Gmail API (sin SMTP)
EMAIL_DELIVERY_ENABLED=true
GMAIL_API_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GMAIL_API_CLIENT_SECRET=tu_client_secret
GMAIL_API_REFRESH_TOKEN=tu_refresh_token
GMAIL_API_SENDER=tu_correo@gmail.com
GMAIL_API_TIMEOUT_SECONDS=15

